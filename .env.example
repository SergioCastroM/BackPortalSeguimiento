# Base de datos
# Opción 1: Azure SQL (recomendado en producción). Definir las 4 variables:
AZURE_SQL_SERVER=tu-servidor.database.windows.net
AZURE_SQL_DATABASE=PortalSeguimientos
AZURE_SQL_USER=tu_usuario
AZURE_SQL_PASSWORD=tu_contraseña
# Opcional: driver (por defecto ODBC Driver 17 for SQL Server)
# AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# Opción 2: URL directa (si no usas las variables de arriba)
# DATABASE_URL=sqlite:///./plan_accion.db
# DATABASE_URL=mssql+pyodbc://user:pass@servidor.database.windows.net:1433/PortalSeguimientos?driver=ODBC+Driver+17+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# App
SECRET_KEY=change-me-in-production-minimum-32-characters
FRONTEND_URL=http://localhost:5173
